{
  "$schema": "vscode://schemas/color-theme",
  "name": "Terracotta Dark",
  "type": "dark",
  "colors": {
    "focusBorder": "#000000f500",
    "foreground": "#D9AFA7",
    "disabledForeground": "#7B534E",
    "descriptionForeground": "#7B534E",
    "errorForeground": "#E07B5F",
    "selection.background": "#4A2C2C40",
    "progressBar.background": "#FF6B4A",

    "banner.background": "#1a0f0fd4",
    "banner.foreground": "#D9AFA7",
    "banner.iconForeground": "#D9AFA7",

    // #region Window
    "window.activeBorder": "#4A2C2C",
    "window.inactiveBorder": "#2a1a1a",
    // #endregion

    // #region Scrollbar & Minimap
    "scrollbar.shadow": "#000000f5",
    "scrollbarSlider.background": "#4A2C2C80",
    "scrollbarSlider.activeBackground": "#C45A3F80",
    "scrollbarSlider.hoverBackground": "#4A2C2Caa",

    "editorOverviewRuler.border": "#000000f500",
    "editorOverviewRuler.background": "#0d0808",
    "editorOverviewRuler.findMatchForeground": "#C45A3F",
    "editorOverviewRuler.rangeHighlightForeground": "#2a1515",
    "editorOverviewRuler.wordHighlightForeground": "#2a1515",
    "editorOverviewRuler.wordHighlightStrongForeground": "#3d1f1f",
    "editorOverviewRuler.addedForeground": "#66a76b",
    "editorOverviewRuler.deletedForeground": "#a76666",
    "editorOverviewRuler.modifiedForeground": "#9975b1",
    "editorOverviewRuler.warningForeground": "#d8b762",
    "editorOverviewRuler.errorForeground": "#d44c4c",
    "editorOverviewRuler.infoForeground": "#E07B5F",

    "minimap.background": "#0d0808",
    "minimap.errorHighlight": "#862828",
    "minimap.warningHighlight": "#866928",
    "minimap.findMatchHighlight": "#C45A3F",
    "minimap.selectionHighlight": "#4A2C2C4b",
    "minimap.selectionOccurrenceHighlight": "#4A2C2C4b",
    "minimapSlider.background": "#4A2C2C70",
    "minimapSlider.activeBackground": "#4A2C2C90",
    "minimapSlider.hoverBackground": "#4A2C2Ca2",
    // #endregion

    // #region Title Bar & Status Bar
    "titleBar.activeForeground": "#D9AFA7",
    "titleBar.activeBackground": "#0d0808",
    "titleBar.inactiveForeground": "#7B534E",
    "titleBar.inactiveBackground": "#0d0808",
    "titleBar.border": "#2a1a1a",

    "statusBar.foreground": "#D9AFA7",
    "statusBar.background": "#0d0808",
    "statusBar.border": "#2a1a1a",
    "statusBar.noFolderForeground": "#D9AFA7",
    "statusBar.noFolderBackground": "#0d0808",
    "statusBar.noFolderBorder": "#2a1a1a",
    "statusBar.debuggingForeground": "#fff",
    "statusBar.debuggingBackground": "#614a60",
    "statusBar.debuggingBorder": "#755974",
    "statusBarItem.hoverBackground": "#4A2C2C30",
    "statusBarItem.prominentHoverBackground": "#C45A3F60",
    "statusBarItem.prominentForeground": "#ffffff",
    "statusBarItem.prominentBackground": "#A0392F",
    // #endregion

    // #region Activity Bar
    "activityBar.activeBorder": "#FF6B4A",
    "activityBar.foreground": "#FF6B4A",
    "activityBar.background": "#0d0808",
    "activityBar.border": "#2a1a1a",
    "activityBar.dropBorder": "#FF6B4A",
    "activityBar.inactiveForeground": "#7B534E",
    "activityBarBadge.background": "#A0392F",
    // #endregion

    // #region SideBar & List
    "widget.shadow": "#000000f5",
    "badge.background": "#A0392F",
    "panel.background": "#0d0808",
    "panel.border": "#2a1a1a",

    "sideBar.foreground": "#7B534E",
    "sideBar.background": "#0a0606",
    "sideBar.border": "#2a1a1a",
    "sideBarTitle.foreground": "#7B534E",
    "sideBarSectionHeader.foreground": "#7B534E",
    "sideBarSectionHeader.background": "#000000f500",
    "sideBarSectionHeader.border": "#000000f500",
    "sideBar.dropBackground": "#1a0f0f",

    "quickInputTitle.background": "#1a0f0f",
    "list.activeSelectionIconForeground": "#D9AFA7",
    "list.activeSelectionForeground": "#FF6B4A",
    "list.activeSelectionBackground": "#4A2C2C30",
    "list.inactiveSelectionIconForeground": "#D9AFA7",
    "list.inactiveSelectionForeground": "#FF6B4A",
    "list.inactiveSelectionBackground": "#4A2C2C20",
    "list.hoverForeground": "#FF6B4A",
    "list.hoverBackground": "#4A2C2C20",
    "list.filterMatchBackground": "#2a1515",
    "list.filterMatchBorder": "#FF6B4A60",
    "list.errorForeground": "#E07B5F",
    "list.warningForeground": "#d8b762",
    "listFilterWidget.background": "#1a0f0f",
    "listFilterWidget.noMatchesOutline": "#1a0f0f",
    "listFilterWidget.outline": "#FF6B4A",

    "pickerGroup.border": "#2a1a1a",
    "pickerGroup.foreground": "#D9AFA7",

    "editorWidget.foreground": "#D9AFA7",
    "editorWidget.background": "#130c0c",
    "editorWidget.border": "#2a1a1a",
    "editorWidget.resizeBorder": "#2a1a1a",

    "menu.foreground": "#D9AFA7",
    "menu.background": "#130c0c",
    "menu.border": "#2a1a1a",
    "menu.separatorBackground": "#2a1a1a",
    "menu.selectionForeground": "#FF6B4A",
    "menu.selectionBackground": "#4A2C2C30",
    "debugToolBar.background": "#130c0c",
    "debugToolBar.border": "#2a1a1a",

    "editorHoverWidget.foreground": "#D9AFA7",
    "editorHoverWidget.background": "#130c0c00",
    "editorHoverWidget.border": "#2a1a1a",
    "tree.indentGuidesStroke": "#2a1a1a",
    "tree.tableColumnsBorder": "#2a1a1a",
    // #endregion

    // #region Tabs & Breadcrumb
    "tab.border": "#2a1a1a",
    "tab.activeBorder": "#FF6B4A",
    "tab.activeBorderTop": "#FF6B4A",
    "tab.activeBackground": "#000000f5",
    "tab.activeForeground": "#FF6B4A",
    "tab.inactiveForeground": "#7B534E",
    "tab.inactiveBackground": "#000000f5",

    "editorGroup.border": "#2a1a1a",
    "editorGroupHeader.tabsBackground": "#000000f5",
    "editorGroupHeader.noTabsBackground": "#000000f5",
    "editorGroupHeader.border": "#2a1a1a",
    "editorGroupHeader.tabsBorder": "#2a1a1a",

    "breadcrumb.background": "#000000f5",
    "breadcrumb.foreground": "#7B534E",
    "breadcrumb.focusForeground": "#E07B5F",
    "breadcrumb.activeSelectionForeground": "#E07B5F",
    // #endregion

    // #region Icons
    "icon.foreground": "#D9AFA7",
    "toolbar.hoverOutline": "#000000f500",
    "toolbar.activeBackground": "#2a1a1a",
    "toolbar.hoverBackground": "#2a1a1a",

    "panelTitle.activeForeground": "#FF6B4A",
    "panelTitle.activeBorder": "#FF6B4A",
    "panelTitle.inactiveForeground": "#D9AFA7",

    "inputOption.activeBackground": "#000000f500",
    "inputOption.activeBorder": "#000000f500",
    "inputOption.activeForeground": "#FF6B4A",
    "inputOption.hoverBackground": "#2a1a1a",
    // #endregion

    // #region Editor
    "editor.foreground": "#D9AFA7",
    "editor.background": "#000000f5",
    "editorCursor.background": "#FF6B4A",
    "editorCursor.foreground": "#FF6B4A",
    "editorBracketMatch.border": "#4A2C2C",
    "editorBracketMatch.background": "#000000f500",
    "peekView.border": "#2a1a1a",
    "peekViewEditor.background": "#0d0808",
    "peekViewEditor.matchHighlightBorder": "#000000f500",
    "peekViewEditor.matchHighlightBackground": "#C45A3F30",
    "peekViewResult.background": "#0a0606",
    "peekViewResult.lineForeground": "#D9AFA7",
    "peekViewResult.selectionForeground": "#FF6B4A",
    "peekViewResult.selectionBackground": "#4A2C2C30",
    "peekViewResult.matchHighlightBackground": "#C45A3F30",
    "peekViewResult.fileForeground": "#D9AFA7",
    "peekViewTitle.background": "#0a0606",
    "peekViewTitleLabel.foreground": "#D9AFA7",
    "peekViewTitleDescription.foreground": "#7B534E",
    "editorError.foreground": "#E07B5F",
    "editorWarning.foreground": "#d8b762",
    "editorWhitespace.foreground": "#4A2C2C20",
    "editorLineNumber.activeForeground": "#FF6B4A",
    "editorLineNumber.foreground": "#4A2C2C",
    "editor.lineHighlightBackground": "#4A2C2C10",
    "editor.selectionBackground": "#4A2C2C50",
    "editor.selectionHighlightBackground": "#4A2C2C30",
    "editor.wordHighlightBackground": "#C45A3F20",
    "editor.wordHighlightStrongBackground": "#C45A3F40",
    "editor.rangeHighlightBackground": "#2a1515",
    "editor.findMatchBackground": "#C45A3F50",
    "editor.findMatchHighlightBackground": "#C45A3F25",
    "editor.findRangeHighlightBackground": "#C45A3F20",
    "editorUnicodeHighlight.background": "#000000f500",
    "editorUnicodeHighlight.border": "#b49a43",
    "debugIcon.breakpointForeground": "#81568b",
    // #endregion

    // #region Error Lens
    "errorLens.errorBackground": "#000000f500",
    "errorLens.errorForeground": "#E07B5F",
    "errorLens.warningBackground": "#000000f500",
    "errorLens.warningForeground": "#d8b762",
    "errorLens.infoBackground": "#000000f500",
    "errorLens.infoForeground": "#E07B5F",
    // #endregion

    // #region Extensions
    "extensionIcon.starForeground": "#aca54a",
    "extensionIcon.preReleaseForeground": "#FF6B4A60",
    // #endregion

    // #region Inputs
    "commandCenter.activeBackground": "#0d0808",
    "commandCenter.background": "#0d0808",
    "commandCenter.border": "#2a1a1a",
    "commandCenter.foreground": "#7B534E",

    "editorLink.activeForeground": "#E07B5F",
    "editorCodeLens.foreground": "#7B534E",

    "button.foreground": "#ffffff",
    "button.background": "#A0392F",
    "button.separator": "#C45A3F",
    "button.secondaryForeground": "#ffffff",
    "button.secondaryBackground": "#4A2C2C",
    "button.secondaryHoverBackground": "#5a3535",

    "keybindingLabel.border": "#A0392F5d",
    "keybindingLabel.bottomBorder": "#A0392F5d",
    "keybindingLabel.foreground": "#D9AFA7",
    "keybindingLabel.background": "#A0392F3f",
    "keybindingTable.headerBackground": "#A0392F3f",

    "input.foreground": "#D9AFA7",
    "input.background": "#0d0808",
    "input.border": "#2a1a1a",
    "input.placeholderForeground": "#7B534E",

    "dropdown.foreground": "#D9AFA7",
    "dropdown.background": "#0d0808",
    "dropdown.border": "#2a1a1a",
    "dropdown.listBackground": "#0d0808",

    "inputValidation.infoForeground": "#ffffff",
    "inputValidation.infoBorder": "#C45A3F",
    "inputValidation.infoBackground": "#A0392F",
    "inputValidation.errorForeground": "#ffffff",
    "inputValidation.errorBorder": "#922b2b",
    "inputValidation.errorBackground": "#862828",
    "inputValidation.warningForeground": "#ffffff",
    "inputValidation.warningBorder": "#92722b",
    "inputValidation.warningBackground": "#866928",

    "textLink.activeForeground": "#FF6B4A",
    "textLink.foreground": "#E07B5F",
    "textBlockQuote.background": "#0d0808",
    "textBlockQuote.border": "#FF6B4A",
    "textPreformat.foreground": "#FF6B4A",
    "textSeparator.foreground": "#2a1a1a",
    // #endregion

    // #region Settings
    "settings.headerForeground": "#FF6B4A",
    "settings.focusedRowBackground": "#130c0cd1",
    "settings.rowHoverBackground": "#130c0cd1",
    "settings.modifiedItemIndicator": "#FF6B4A",
    // #endregion

    // #region Git Decoration
    "editorGutter.modifiedBackground": "#9975b1",
    "editorGutter.deletedBackground": "#a76666",
    "editorGutter.addedBackground": "#66a76b",
    "gitDecoration.ignoredResourceForeground": "#4A2C2C",
    "gitDecoration.modifiedResourceForeground": "#9975b1",
    "gitDecoration.untrackedResourceForeground": "#7580b1",
    "gitDecoration.deletedResourceForeground": "#a76666",
    "gitDecoration.addedResourceForeground": "#66a76b",
    "gitDecoration.conflictingResourceForeground": "#a77e66",
    "gitDecoration.renamedResourceForeground": "#8ea766",

    // Diff
    "diffEditor.border": "#1a0f0f",
    "diffEditor.diagonalFill": "#1a0f0f",
    "diffEditor.insertedLineBackground": "#4f724f25",
    "diffEditor.insertedTextBackground": "#4f724f25",
    "diffEditor.removedLineBackground": "#c72a2a25",
    "diffEditor.removedTextBackground": "#94313125",
    // #endregion

    // #region Terminal
    "terminalCursor.background": "#FF6B4A",
    "terminalCursor.foreground": "#FF6B4A",
    "terminal.foreground": "#D9AFA7",
    "terminal.ansiYellow": "#bdac3c",
    "terminal.ansiBrightYellow": "#c7b53f",
    "terminal.ansiRed": "#d44c4c",
    "terminal.ansiBrightRed": "#cc2323",
    "terminal.ansiGreen": "#22c55e",
    "terminal.ansiBrightGreen": "#23CC61",
    "terminal.ansiBlue": "#5b81b3",
    "terminal.ansiBrightBlue": "#4d93de",
    "terminal.ansiCyan": "#E07B5F",
    "terminal.ansiBrightCyan": "#FF6B4A",
    "terminal.ansiMagenta": "#bb65bb",
    "terminal.ansiBrightMagenta": "#e04be0",
    "terminal.ansiBlack": "#4A2C2C",
    "terminal.ansiBrightBlack": "#7B534E",
    "terminal.ansiWhite": "#D9AFA7",
    "terminal.ansiBrightWhite": "#fff",
    // #endregion

    // #region Pair Bracket
    "editorBracketHighlight.foreground1": "#7B534E",
    "editorBracketHighlight.foreground2": "#C45A3F",
    "editorBracketHighlight.foreground3": "#927486",
    "editorBracketHighlight.foreground4": "#A0392F",
    "editorBracketHighlight.foreground5": "#7d6a5c",
    "editorBracketHighlight.foreground6": "#938479",
    // #endregion
  },
  "tokenColors": [
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#E07B5F"
      }
    },
    {
      "scope": [
        "meta.brace",
        "punctuation",
        "keyword.operator.class",
        "keyword.operator.type.annotation",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#7B534E"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4A2C2C"
      }
    },
    {
      "name": "directives",
      "scope": [
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#685157"
      }
    },
    {
      "name": "directive definition",
      "scope": [
        "entity.name.other.preprocessor",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#7a6b63"
      }
    },
    {
      "name": "keywords",
      "scope": [
        "keyword",
        "storage.modifier.async",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#C45A3F"
      }
    },
    {
      "name": "components",
      "scope": [
        "support.class.component"
      ],
      "settings": {
        "foreground": "#6492c7"
      }
    },
    {
      "scope": [
        "storage",
        "keyword.const.go",
        "keyword.type.go",
        "keyword.struct.go",
        "keyword.function.go",
        "keyword.other.declaration-specifier",
        "entity.name.tag",
        "entity.name.section.markdown",
        "entity.name.section.group-title"
      ],
      "settings": {
        "foreground": "#E07B5F"
      }
    },
    {
      "name": "typings",
      "scope": [
        "support.type",
        "entity.name.type",
        "keyword.other.type"
      ],
      "settings": {
        "foreground": "#D9AFA7"
      }
    },
    {
      "name": "functions",
      "scope": [
        "support.function",
        "entity.name.function",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#8778ae"
      }
    },
    {
      "name": "classes",
      "scope": [
        "support.class",
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.module",
        "entity.other.alias",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FF6B4A"
      }
    },
    {
      "scope": [
        "support.other.namespace",
        "entity.name.type.namespace"
      ],
      "settings": {
        "foreground": "#ad927b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#a09747"
      }
    },
    {
      "name": "strings",
      "scope": [
        "string",
        "markup.inline.raw.string",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#7d9958"
      }
    },
    {
      "scope": [
        "variable.other.link",
        "string.interpolated",
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#97a067"
      }
    },
    {
      "scope": [
        "constant",
        "keyword.other.unit.hexadecimal",
        "fenced_code.block.language"
      ],
      "settings": {
        "foreground": "#ad9d60"
      }
    },
    {
      "scope": [
        "keyword.other.unit.px",
        "storage.type.numeric.bigint"
      ],
      "settings": {
        "foreground": "#c28a5c"
      }
    },
    {
      "name": "variables",
      "scope": [
        "variable",
        "support.variable",
        "constant.other.caps",
        "storage.modifier.package.java",
        "storage.modifier.import.java"
      ],
      "settings": {
        "foreground": "#D9AFA7"
      }
    },
    {
      "name": "this/self",
      "scope": [
        "variable.language.self",
        "variable.language.this",
        "variable.language.special.self",
        "variable.language.special.this"
      ],
      "settings": {
        "foreground": "#A0392F",
        "fontStyle": "bold italic"
      }
    },
    {
      "scope": [
        "variable.language.global"
      ],
      "settings": {
        "foreground": "#A0392F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "attributes/values",
      "scope": [
        "entity.name.tag.yaml",
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8e739c"
      }
    },
    {
      "scope": [
        "markup.inserted.diff",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#60a060"
      }
    },
    {
      "scope": [
        "meta.diff.header.from-file",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#bd6e6e"
      }
    },
    {
      "name": "italic style",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "strikethrough",
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true
}